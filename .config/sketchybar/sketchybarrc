#!/bin/bash

# --- Dracula Colors ---
export BAR_COLOR=0xcc282a36
export ITEM_BG=0xff44475a
export ACCENT_COLOR=0xffbd93f9
export GREEN=0xff50fa7b
export TEXT_COLOR=0xfff8f8f2
export ALT_TEXT=0xff6272a4
export PINK=0xffff79c6
export CYAN=0xff8be9fd
export YELLOW=0xfff1fa8c
export ORANGE=0xffffb86c
export BLUE=0xff8be9fd

# --- Font Config ---
export FONT="JetBrainsMono Nerd Font"
export PLUGIN_DIR="$CONFIG_DIR/plugins"

# --- Events ---
sketchybar --add event aerospace_workspace_change

##### Bar Appearance #####
sketchybar --bar \
  position=top \
  height=34 \
  margin=10 \
  y_offset=8 \
  corner_radius=12 \
  color=$BAR_COLOR

##### Changing Defaults #####
sketchybar --default \
  padding_left=6 \
  padding_right=6 \
  icon.font="$FONT:Bold:15.0" \
  label.font="$FONT:Bold:13.0" \
  icon.color=$TEXT_COLOR \
  label.color=$TEXT_COLOR \
  icon.y_offset=0 \
  label.y_offset=1.5

##### AeroSpace Workspaces #####
SPACE_ICONS=("1" "2" "3" "4" "5" "6")
for sid in "${SPACE_ICONS[@]}"; do
  sketchybar --add item space."$sid" left \
    --set space."$sid" \
    label="$sid" \
    label.padding_left=8 \
    label.padding_right=8 \
    background.height=26 \
    background.corner_radius=8 \
    background.drawing=off \
    click_script="aerospace workspace $sid" \
    script="$PLUGIN_DIR/aerospace.sh $sid" \
    --subscribe space."$sid" aerospace_workspace_change
done

##### Center/Front App #####
sketchybar --add item separator left \
  --set separator label="" \
  label.font="$FONT:Bold:16.0" \
  label.padding_left=4 \
  label.padding_right=8 \
  label.color=$GREEN \
  \
  --add item front_app left \
  --set front_app label.padding_left=4 \
  label.color=$TEXT_COLOR \
  script="$PLUGIN_DIR/front_app.sh" \
  --subscribe front_app front_app_switched

##### Right Side (Pill 2: Mac Stuff) #####
sketchybar --add item clock right \
  --set clock update_freq=10 \
  icon="󱑂" icon.color=$ACCENT_COLOR \
  label.width=95 label.align=right \
  padding_right=12 script="$PLUGIN_DIR/clock.sh"

sketchybar --add item battery right \
  --set battery update_freq=120 \
  icon="󰁹" icon.color=$PINK \
  label.width=45 label.align=center \
  script="$PLUGIN_DIR/battery.sh" \
  --subscribe battery system_woke power_source_change

sketchybar --add item volume right \
  --set volume icon.color=$CYAN \
  label.width=35 label.align=center \
  script="$PLUGIN_DIR/volume.sh" \
  --subscribe volume volume_change

##### Spacer #####
sketchybar --add item right_spacer right \
  --set right_spacer width=15

##### Right Side (Pill 1: Hardware) #####
sketchybar --add item ram right \
  --set ram update_freq=2 \
  icon="󰘚" icon.color=$ORANGE \
  label.width=35 label.align=center \
  script="$PLUGIN_DIR/ram.sh"

sketchybar --add item cpu right \
  --set cpu update_freq=2 \
  icon="󰍛" icon.color=$YELLOW \
  label.width=35 label.align=center \
  script="$PLUGIN_DIR/cpu.sh"

sketchybar --add item brew right \
  --set brew update_freq=1800 \
  icon="󰏗" icon.color=$GREEN \
  label.width=25 label.align=center \
  padding_left=12 \
  script="$PLUGIN_DIR/brew.sh"

##### Brackets #####
sketchybar --add bracket mac_pill clock battery volume \
  --set mac_pill background.color=$ITEM_BG \
  background.corner_radius=12 \
  background.height=28

sketchybar --add bracket hardware_pill ram cpu brew \
  --set hardware_pill background.color=$ITEM_BG \
  background.corner_radius=12 \
  background.height=28

##### Init #####
sketchybar --update
sketchybar --trigger aerospace_workspace_change FOCUSED_WORKSPACE=$(aerospace list-workspaces --focused)
